---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoEmbed from '../../components/DemoEmbed.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, tagline, type, platforms, tags, images, links, demo } = project.data;

const isPlaceholder = (url?: string) => !url || url.startsWith('PLACEHOLDER');
const icon = images[0];
const screenshots = images.slice(1);
const typeLabel = type.charAt(0).toUpperCase() + type.slice(1);
---

<BaseLayout title={title} description={tagline}>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <a href="/projects" class="text-sm font-medium text-brand-600 hover:underline">← All projects</a>

    <div class="mt-6 flex items-start gap-5">
      {
        icon && (
          <img
            src={icon}
            alt={`App icon for ${title}`}
            class="size-20 shrink-0 object-contain rounded-2xl shadow-sm"
            loading="lazy"
            onerror="this.src='/images/placeholder-project.svg'"
          />
        )
      }
      <div class="min-w-0 pt-0.5">
        <p class="text-sm font-medium uppercase tracking-wide text-brand-600">
          {typeLabel} · {platforms.join(', ')}
        </p>
        <h1 class="mt-1 text-2xl font-bold text-ink sm:text-3xl">{title}</h1>
        <p class="mt-2 text-lg text-ink-muted">{tagline}</p>
      </div>
    </div>

    {
      screenshots.length > 0 && (
        <div class="mt-10 space-y-4">
          {screenshots.map((src) => (
            <img
              src={src}
              alt={`${title} screenshot`}
              class="w-full rounded-xl border border-border shadow-sm"
              loading="lazy"
              onerror="this.src='/images/placeholder-project.svg'"
            />
          ))}
        </div>
      )
    }

    {
      demo && (
        <div class="mt-10">
          <h2 class="text-xl font-semibold text-ink mb-4">Try it</h2>
          <DemoEmbed src={demo} title={`${title} demo`} />
        </div>
      )
    }

    <div class="mt-10 prose">
      <Content />
    </div>

    <div class="mt-8 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full bg-surface-muted px-3 py-1 text-xs text-ink-muted border border-border">
          {tag}
        </span>
      ))}
    </div>

    {
      links && (
        <div class="mt-10 flex flex-wrap gap-4 pt-8 border-t border-border">
          {links.github && (
            <a
              href={links.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-brand-600 hover:underline"
            >
              GitHub →
            </a>
          )}
          {links.website && !isPlaceholder(links.website) && (
            <a
              href={links.website}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-brand-600 hover:underline"
            >
              Website →
            </a>
          )}
          {links.playStore && !isPlaceholder(links.playStore) && (
            <a
              href={links.playStore}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-brand-600 hover:underline"
            >
              Google Play →
            </a>
          )}
          {links.appStore && !isPlaceholder(links.appStore) && (
            <a
              href={links.appStore}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-brand-600 hover:underline"
            >
              App Store →
            </a>
          )}
          {links.blog && !isPlaceholder(links.blog) && (
            <a
              href={links.blog}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-brand-600 hover:underline"
            >
              Blog →
            </a>
          )}
        </div>
      )
    }
  </article>
</BaseLayout>
