---
import { getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SkillTags from '../components/SkillTags.astro';
import { getCollection } from 'astro:content';
import site from '../data/site.json';
import headshot from '../assets/images/emily-headshot.jpg';
import { imagePresets } from '../lib/images';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const avatar = imagePresets.avatar;
const lcpImage = await getImage({
  src: headshot,
  width: avatar.width,
  height: avatar.height,
  format: 'webp',
});
---

<BaseLayout title={site.name} lcpImage={lcpImage.src}>
  <Hero />
  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="flex items-end justify-between gap-4 mb-8">
      <div>
        <h2 class="text-2xl font-bold text-ink">Featured projects</h2>
        <p class="mt-2 text-ink-muted">Greenfield builds, production apps, and codebases brought back from the brink.</p>
      </div>
      <a href="/projects" class="text-sm font-medium text-brand-600 hover:underline shrink-0">
        View all →
      </a>
    </div>
    <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
      {
        featured.map((project) => (
          <ProjectCard
            title={project.data.title}
            tagline={project.data.tagline}
            type={project.data.type}
            platforms={project.data.platforms}
            tags={project.data.tags}
            images={project.data.images}
            links={project.data.links}
            href={`/projects/${project.id}`}
          />
        ))
      }
    </div>
  </section>
  <section class="bg-surface-muted border-y border-border">
    <div class="mx-auto max-w-5xl px-6 py-16">
      <SkillTags skills={site.skills} />
    </div>
  </section>
  <section class="mx-auto max-w-5xl px-6 py-16 text-center">
    <h2 class="text-2xl font-bold text-ink">Let's work together</h2>
    <p class="mt-3 text-ink-muted max-w-xl mx-auto">
      Messy repo, AI prototype that needs turning into a real product, or a greenfield app to build
      from scratch? I'm open to senior, lead, and contract Flutter roles — Bristol, hybrid, or remote.
    </p>
    <a
      href="/contact"
      class="mt-6 inline-flex items-center rounded-lg bg-brand-600 px-6 py-3 text-sm font-medium text-white hover:bg-brand-700 transition-colors"
    >
      Get in touch
    </a>
  </section>
</BaseLayout>
