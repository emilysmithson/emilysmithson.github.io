---
import OptimizedImage from './OptimizedImage.astro';

interface Props {
  heading: string;
  image: string;
  alt?: string;
  align?: 'left' | 'right';
}

const { heading, image, alt, align = 'right' } = Astro.props;
---

<section
  class:list={[
    'not-prose my-12 flex flex-col gap-8',
    align === 'right' ? 'md:flex-row' : 'md:flex-row-reverse',
    'md:items-center md:gap-10',
  ]}
>
  <figure class="mx-auto shrink-0 md:mx-0">
    <OptimizedImage
      src={image}
      alt={alt ?? heading}
      preset="feature"
      class="w-[220px] rounded-2xl border border-border shadow-md sm:w-[240px]"
    />
  </figure>
  <div class="min-w-0 flex-1">
    <h2 class="text-xl font-semibold text-ink sm:text-2xl">{heading}</h2>
    <div class="prose mt-3">
      <slot />
    </div>
  </div>
</section>
