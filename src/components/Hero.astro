---
import site from '../data/site.json';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section class:list={['bg-surface-muted border-b border-border', compact ? 'py-12' : 'py-20']}>
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex flex-col md:flex-row md:items-center gap-10">
      <div class="shrink-0">
        <img
          src={site.photo}
          alt={`Portrait of ${site.name}`}
          width="200"
          height="200"
          class="w-40 h-40 md:w-48 md:h-48 rounded-2xl object-cover object-top shadow-lg ring-2 ring-white"
          onerror="this.src='/images/placeholder-avatar.svg'"
        />
      </div>
      <div class="flex-1">
        <p class="text-sm font-medium text-brand-600 mb-2">{site.title} · {site.location}</p>
        <h1 class="text-3xl md:text-4xl font-bold text-ink tracking-tight">{site.name}</h1>
        <p class="mt-4 text-lg text-ink-muted max-w-2xl leading-relaxed">{site.tagline}</p>
        <p class="mt-3 text-sm text-ink-muted">{site.availability}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/projects"
            class="inline-flex items-center rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-brand-700 transition-colors"
          >
            View my work
          </a>
          <a
            href={site.cvPdf}
            class="inline-flex items-center rounded-lg border border-border bg-surface px-5 py-2.5 text-sm font-medium text-ink hover:border-brand-500 transition-colors"
          >
            Download CV
          </a>
          <a
            href="/contact"
            class="inline-flex items-center rounded-lg border border-border bg-surface px-5 py-2.5 text-sm font-medium text-ink hover:border-brand-500 transition-colors"
          >
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
