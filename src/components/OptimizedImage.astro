---
import { Image } from 'astro:assets';
import { imagePresets, resolveImage, type ImagePreset } from '../lib/images';

interface Props {
  src: string;
  alt: string;
  preset?: ImagePreset;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  src,
  alt,
  preset = 'screenshot',
  class: className,
  loading = 'lazy',
  fetchpriority,
} = Astro.props;

const metadata = resolveImage(src);
const sizes = imagePresets[preset];
const width = sizes.width;
const height = 'height' in sizes ? sizes.height : undefined;
---

{
  metadata ? (
    <Image
      src={metadata}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      fetchpriority={fetchpriority}
      formats={['avif', 'webp', 'png', 'jpeg']}
    />
  ) : (
    <img
      src={src}
      alt={alt}
      class={className}
      loading={loading}
      fetchpriority={fetchpriority}
      onerror="this.src='/images/placeholder-project.svg'"
    />
  )
}
