---
interface Props {
  title: string;
  company: string;
  start: string;
  end: string;
  highlight: string;
  tags: string[];
}

const { title, company, start, end, highlight, tags } = Astro.props;
---

<article class="relative pl-8 pb-10 border-l-2 border-border last:pb-0">
  <div class="absolute -left-[9px] top-1 h-4 w-4 rounded-full border-2 border-brand-500 bg-surface"></div>
  <p class="text-sm font-medium text-brand-600">{start} – {end}</p>
  <h3 class="mt-1 text-lg font-semibold text-ink">{title}</h3>
  <p class="text-ink-muted font-medium">{company}</p>
  <p class="mt-3 text-sm text-ink-muted leading-relaxed">{highlight}</p>
  <div class="mt-4 flex flex-wrap gap-1.5">
    {tags.map((tag) => (
      <span class="rounded-full bg-surface-muted px-2.5 py-0.5 text-xs text-ink-muted border border-border">
        {tag}
      </span>
    ))}
  </div>
</article>
